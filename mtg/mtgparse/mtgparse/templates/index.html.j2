<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTG Tournaments</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f0f2f5;
            color: #222;
            padding: 24px;
        }

        h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 24px;
            color: #1a1a2e;
        }

        h2 {
            font-size: 1rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 16px;
        }

        section { margin-bottom: 32px; }

        .tourn-table {
            border-collapse: separate;
            border-spacing: 0;
            background: white;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            font-size: 0.88rem;
        }

        .tourn-table th, .tourn-table td {
            padding: 10px 16px;
            border-bottom: 1px solid #e8e8e8;
            white-space: nowrap;
        }

        .tourn-table tbody tr:last-child td { border-bottom: none; }

        .tourn-table thead th {
            background: #1e3a5f;
            color: white;
            font-weight: 600;
            text-align: left;
        }

        .tourn-table thead th:first-child { border-top-left-radius: 10px; }
        .tourn-table thead th:last-child  { border-top-right-radius: 10px; }
        .tourn-table tbody tr:last-child td:first-child { border-bottom-left-radius: 10px; }
        .tourn-table tbody tr:last-child td:last-child  { border-bottom-right-radius: 10px; }

        .tourn-table tbody tr:hover td { background: #f0f7ff; }

        .tourn-table td.col-title { font-weight: 600; }

        .badge {
            font-size: 0.70rem;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 4px;
            background: #e8f0fe;
            color: #1a56c4;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .tourn-table td a {
            color: #1a73e8;
            text-decoration: none;
        }

        .tourn-table td a:hover { text-decoration: underline; }

        .static-links {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .static-links a {
            font-size: 0.88rem;
            color: #1a73e8;
            text-decoration: none;
        }

        .static-links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <h1>MTG Tournaments</h1>

{#- Pre-pass: classify each tournament #}
{%- set ns = namespace(has_active=false, has_upcoming=false, has_past=false) %}
{%- for id, meta in tournaments %}
    {%- if id not in has_any_data %}
        {%- set ns.has_upcoming = true %}
    {%- elif meta.active %}
        {%- set ns.has_active = true %}
    {%- else %}
        {%- set ns.has_past = true %}
    {%- endif %}
{%- endfor %}

{#- Macro to render a table of tournaments filtered by a category #}
{%- macro tourn_table(category) %}
    <table class="tourn-table">
        <thead>
            <tr>
                <th>Tournament</th>
                <th>Format</th>
                {% if category != 'upcoming' %}
                <th>Leaderboard</th>
                <th>Matchups</th>
                <th>Deck Clustering</th>
                {% endif %}
                <th>Data Source</th>
                <th>Start Date</th>
            </tr>
        </thead>
        <tbody>
            {%- for id, meta in tournaments %}
            {%- if (category == 'upcoming' and id not in has_any_data)
                or (category == 'active'   and id in has_any_data and meta.active)
                or (category == 'past'     and id in has_any_data and not meta.active) %}
            <tr>
                <td class="col-title">{{ meta.title }}</td>
                <td><span class="badge">{{ meta.format }}</span></td>
                {% if category != 'upcoming' %}
                <td>{% if id in has_any_data %}<a href="leaderboard.html?id={{ id }}">Leaderboard</a>{% endif %}</td>
                <td>{% if id in has_any_data %}<a href="arch_matchup.html?id={{ id }}">Matchups</a>{% endif %}</td>
                <td>{% if id in has_embeddings %}<a href="embeddings-{{ id }}.html">Deck Clustering</a>{% endif %}</td>
                {% endif %}
                <td>{% if meta.get_url() %}<a href="{{ meta.get_url() }}" target="_blank" rel="noopener noreferrer">Data Source</a>{% endif %}</td>
                <td><time class="local-date" datetime="{{ meta.start_date.isoformat() }}">{{ meta.start_date.strftime('%Y-%m-%d') }}</time></td>
            </tr>
            {%- endif %}
            {%- endfor %}
        </tbody>
    </table>
{%- endmacro %}

    {%- if ns.has_active %}
    <section>
        <h2>Active Contests</h2>
        {{ tourn_table('active') }}
    </section>
    {%- endif %}

    {%- if ns.has_upcoming %}
    <section>
        <h2>Upcoming Contests</h2>
        {{ tourn_table('upcoming') }}
    </section>
    {%- endif %}

    {%- if ns.has_past %}
    <section>
        <h2>Past Contests</h2>
        {{ tourn_table('past') }}
    </section>
    {%- endif %}

    <section>
        <h2>Tools</h2>
        <div class="static-links">
            <a href="rank_calculator.html">Rank Calculator</a>
        </div>
    </section>
    <script>
    for (const el of document.querySelectorAll('time.local-date')) {
        const d = new Date(el.getAttribute('datetime'));
        el.textContent = d.toLocaleString(undefined, { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', hour12: true, timeZoneName: 'short' });
    }
    </script>
</body>
</html>
